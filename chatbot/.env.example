# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# n8n API key — generate in n8n Settings → API → Create API Key
N8N_API_KEY=your_n8n_api_key_here

# n8n base URL reachable from the chatbot container
# In docker-compose: http://n8n:5678
# For local dev without docker: http://localhost:5678
N8N_BASE_URL=http://n8n:5678

# Port for the chatbot server
PORT=3000
